}

local BLOCKED_PROMPT_NAMES = {
    LeashProximityPrompt = true,
    BreakOutProximityPrompt = true,
    MuzzleProximityPrompt = true,
}

local function isBlocked(prompt)
    -- Bloquer par nom du prompt
    if BLOCKED_PROMPT_NAMES[prompt.Name] then
        return true
    end
    -- Ancienne vérification par grand-parent
    local grandparent = prompt.Parent and prompt.Parent.Parent
    if grandparent then
        for _, name in ipairs(BLOCKED_GRANDPARENTS) do
            if grandparent.Name == name then return true end
        end
    end
    return false
end

local promptCache = {}

local function updatePromptCache()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            promptCache[obj] = true
        end
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("ProximityPrompt") then
        promptCache[obj] = true
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if obj:IsA("ProximityPrompt") then
        promptCache[obj] = nil
    end
end)

local function setAutoGrab(enabled, onlyDuringGivePanel)
    autoGrabEnabled = enabled
    if onlyDuringGivePanel ~= nil then
        autoGrabActiveOnlyDuringGivePanel = onlyDuringGivePanel
    end
    
    if not onlyDuringGivePanel then
        Config.AutoGrab = enabled
        SaveConfig()
    end
    
    if autoGrabConnection then
        autoGrabConnection:Disconnect()
        autoGrabConnection = nil
    end
    
    if not enabled then return end
    
    updatePromptCache()
    
    autoGrabConnection = RunService.Heartbeat:Connect(function(dt)
        -- Si Auto Grab est réservé AU give panel, vérifier s'il est actif
        if autoGrabActiveOnlyDuringGivePanel then
            if not autoGrabEnabled then return end
        elseif not autoGrabEnabled then
            return
        end
        
        autoGrabTicker = autoGrabTicker + dt
        if autoGrabTicker < 0.1 then return end
        autoGrabTicker = 0
        
        local char = LocalPlayer.Character
        if not char then return end
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        local rootPos = rootPart.Position
        local now = tick()
        local GRAB_RANGE = 15
        local COOLDOWN = 0.5
        
        for prompt in pairs(promptCache) do
            if prompt and prompt.Enabled and not isBlocked(prompt) then
                local part = prompt.Parent
                if part and part:IsA("BasePart") then
                    local dist = (part.Position - rootPos).Magnitude
                    local range = math.min(prompt.MaxActivationDistance, GRAB_RANGE)
                    
                    if dist <= range and (not autoGrabLastGrab[prompt] or now - autoGrabLastGrab[prompt] > COOLDOWN) then
                        autoGrabLastGrab[prompt] = now
                        pcall(function()
                            fireproximityprompt(prompt)
                        end)
                    end
                end
            end
        end
    end)
end

