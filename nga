local function waitForNewTool(oldToolSet, timeout, expectedItemName)
    local start = tick()
    repeat
        task.wait(0.05)
        local currentTools = {}
        local bp = LocalPlayer.Backpack
        local char = LocalPlayer.Character
        if bp then
            for _, tool in pairs(bp:GetChildren()) do
                if tool:IsA("Tool") then currentTools[tool.Name] = true end
            end
        end
        if char then
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then currentTools[tool.Name] = true end
            end
        end
        for name, _ in pairs(currentTools) do
            if not oldToolSet[name] then
                if expectedItemName and name ~= expectedItemName then
                    oldToolSet[name] = true   -- ignorer les mauvais outils
                else
                    return name
                end
            end
        end
    until tick() - start > timeout
    return nil
end

