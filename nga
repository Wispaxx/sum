-- ====== TELEPORT PANEL EDIT MODE ======
local tpEditMode     = false
local tpEditOverlays = {}

local function applyTeleportPanelOrder()
    local order = Config.TeleportPanelOrder
    if not order or #order == 0 then
        for i, item in ipairs(tpItemsList) do item.row.LayoutOrder = i end
        return
    end
    local idxToPos = {}
    for pos, idx in ipairs(order) do idxToPos[idx] = pos end
    for _, item in ipairs(tpItemsList) do
        item.row.LayoutOrder = idxToPos[item.idx] or item.idx
    end
end

local function saveTeleportPanelOrder()
    local sorted = {}
    for _, item in ipairs(tpItemsList) do table.insert(sorted, item) end
    table.sort(sorted, function(a, b) return a.row.LayoutOrder < b.row.LayoutOrder end)
    local order = {}
    for _, item in ipairs(sorted) do table.insert(order, item.idx) end
    Config.TeleportPanelOrder = order
    SaveConfig()
end

local function getTpNeighbors(item)
    local myLO = item.row.LayoutOrder
    local above, below = nil, nil
    local aboveLO, belowLO = -math.huge, math.huge
    for _, other in ipairs(tpItemsList) do
        if other ~= item then
            local lo = other.row.LayoutOrder
            if lo < myLO and lo > aboveLO then aboveLO = lo; above = other end
            if lo > myLO and lo < belowLO then belowLO = lo; below = other end
        end
    end
    return above, below
end

local function enterTeleportEditMode()
    tpEditMode = true
    tEditBtn.Text = "💾 Save"
    tEditBtn.TextColor3 = Theme.Success
    for _, item in ipairs(tpItemsList) do
        local btn = item.row:FindFirstChild("ActionBtn")
        if btn then btn.Visible = false end
        -- Flèches à droite (remplacent visuellement le bouton TP)
        local captItem = item
        local ov = CreateReorderOverlay(item.row, -10,
            function()  -- ▲
                local above, _ = getTpNeighbors(captItem)
                if above then
                    local lo = captItem.row.LayoutOrder
                    captItem.row.LayoutOrder = above.row.LayoutOrder
                    above.row.LayoutOrder = lo
                end
            end,
            function()  -- ▼
                local _, below = getTpNeighbors(captItem)
                if below then
                    local lo = captItem.row.LayoutOrder
                    captItem.row.LayoutOrder = below.row.LayoutOrder
                    below.row.LayoutOrder = lo
                end
            end
        )
        table.insert(tpEditOverlays, {ov = ov, btn = btn})
    end
end

local function exitTeleportEditMode()
    tpEditMode = false
    tEditBtn.Text = "✏ Edit"
    tEditBtn.TextColor3 = Theme.Accent1
    for _, entry in ipairs(tpEditOverlays) do
        if entry.ov and entry.ov.Parent then entry.ov:Destroy() end
        if entry.btn then entry.btn.Visible = true end
    end
    tpEditOverlays = {}
    saveTeleportPanelOrder()
    ShowNotification("TELEPORT", "Order saved!")
end

tEditBtn.MouseButton1Click:Connect(function()
    if not tpEditMode then enterTeleportEditMode() else exitTeleportEditMode() end
end)

