-- ====== Auto Heal Targets (heal specific players when nearby) ======
local healTargetsLoop = nil
local activeTargetHealing = false

local function initAutoHealTargets()
    local MedKitRemote = game:GetService("ReplicatedStorage")
        :WaitForChild("RemoteEvents")
        :WaitForChild("Miscs")
        :WaitForChild("MedKitRemote")

    local threadRunning = true
    healTargetsLoop = { Disconnect = function() threadRunning = false end }

    task.spawn(function()
        while threadRunning do
            task.wait(0.3)
            
            local char = LocalPlayer.Character
            if not char then continue end
            
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            
            -- Get list of players to heal from config
            if not Config.HealPlayers then Config.HealPlayers = {} end
            
            -- Find nearest target player who needs healing
            local nearestTarget = nil
            local nearestDist = 15 -- MAX 15 STUDS for heal targets
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    -- Check if this player is in the heal list
                    local playerUserId = tostring(player.UserId)
                    if Config.HealPlayers[playerUserId] then
                        local pChar = player.Character
                        local pHum = pChar:FindFirstChildOfClass("Humanoid")
                        if pHum and pHum.Health > 0 and pHum.Health < pHum.MaxHealth then
                            local pHRP = pChar:FindFirstChild("HumanoidRootPart")
                            if pHRP then
                                local dist = (hrp.Position - pHRP.Position).Magnitude
                                if dist <= 15 and dist < nearestDist then
                                    nearestDist = dist
                                    nearestTarget = player
                                end
                            end
                        end
                    end
                end
            end
            
            -- Heal the target if found
            if nearestTarget and not activeTargetHealing then
                activeTargetHealing = true
                
                local targetChar = nearestTarget.Character
                local targetHum = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
                
                if targetHum and targetHum.Health > 0 then
                    ShowNotification("Heal Targets", "Healing " .. nearestTarget.Name .. " (distance: " .. math.floor(nearestDist) .. " studs)")
                    
                    -- Get or create MedKit
                    local medkit = char:FindFirstChild("MedKit") or LocalPlayer.Backpack:FindFirstChild("MedKit")
                    
                    if not medkit then
                        -- Try to grab a MedKit
                        local bodyCF = CFrame.new(-61.5462914, 13.6999979, 161.633987, -0.999899805, 6.09817663e-09, -0.014156987, 5.98846173e-09, 1, 7.79229037e-09, 0.014156987, 7.70673125e-09, -0.999899805)
                        local camCF = CFrame.new(-60.8854599, 29.02915, 150.402008, -0.998451114, -0.0418721698, 0.0366369784, 0, 0.658492804, 0.75258708, -0.055637639, 0.751421392, -0.65747273)
                        grabItem(game.Workspace.Map.Vets.Important.DoctorMedKitShelf.Medkit, "Medkit", bodyCF, camCF)
                        task.wait(0.3)
                        medkit = char:FindFirstChild("MedKit") or LocalPlayer.Backpack:FindFirstChild("MedKit")
                    end
                    
                    if medkit then
                        -- Save current tool
                        local currentTool = char:FindFirstChildWhichIsA("Tool")
                        
                        -- Equip MedKit
                        if medkit.Parent ~= char then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hum then hum:EquipTool(medkit) end
                            task.wait(0.2)
                        end
                        
                        -- Heal the target
                        for i = 1, 3 do
                            pcall(function() 
                                MedKitRemote:FireServer(true, targetChar) 
                            end)
                            task.wait(0.1)
                        end
                        
                        -- Unequip
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then hum:UnequipTools() end
                        
                        -- Restore previous tool
                        if currentTool and currentTool ~= medkit then
                            task.wait(0.1)
                            if hum then hum:EquipTool(currentTool) end
                        end
                        
                        ShowNotification("Heal Targets", nearestTarget.Name .. " healed!")
                    end
                end
                
                activeTargetHealing = false
                task.wait(1)
            end
        end
    end)
end

