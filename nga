local function AddFurryEars(parent, options)
    if not parent then return end

    options = options or {}
    local size = options.Size or 34
    local y = options.Y or -4
    local leftOffset = options.LeftOffset or 24
    local rightOffset = options.RightOffset or leftOffset
    local z = options.ZIndex or 30

    local function makeEar(side)
        local isLeft = side == "Left"
        local x = isLeft and UDim2.new(0, leftOffset, 0, y) or UDim2.new(1, -rightOffset - size, 0, y)
        local rotation = isLeft and -22 or 22

        local outer = Instance.new("TextLabel", parent)
        outer.Name = "FurryEar" .. side .. "Outer"
        outer.Size = UDim2.new(0, size, 0, size)
        outer.Position = x
        outer.BackgroundTransparency = 1
        outer.Text = "▲"
        outer.Font = Enum.Font.GothamBlack
        outer.TextSize = size
        outer.TextColor3 = Theme.Accent1
        outer.TextStrokeColor3 = Theme.Accent2
        outer.TextStrokeTransparency = 0.25
        outer.Rotation = rotation
        outer.ZIndex = z
        outer.Visible = Config.Theme == "Furry"

        local innerSize = math.floor(size * 0.48)
        local inner = Instance.new("TextLabel", parent)
        inner.Name = "FurryEar" .. side .. "Inner"
        inner.Size = UDim2.new(0, innerSize, 0, innerSize)
        inner.Position = isLeft
            and UDim2.new(0, leftOffset + math.floor(size * 0.26), 0, y + math.floor(size * 0.3))
            or UDim2.new(1, -rightOffset - math.floor(size * 0.74), 0, y + math.floor(size * 0.3))
        inner.BackgroundTransparency = 1
        inner.Text = "▲"
        inner.Font = Enum.Font.GothamBlack
        inner.TextSize = innerSize
        inner.TextColor3 = Theme.Surface
        inner.TextStrokeTransparency = 1
        inner.Rotation = rotation
        inner.ZIndex = z + 1
        inner.Visible = Config.Theme == "Furry"
    end

    makeEar("Left")
    makeEar("Right")
end

