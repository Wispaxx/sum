-- Fonction pour vérifier si un joueur a la bulle d'apparition
local function hasSpawnBubble(pChar, playerName)
    if not pChar then return false end
    
    -- Vérifier uniquement les parts directement autour du HumanoidRootPart
    local hrp = pChar:FindFirstChild("HumanoidRootPart")
    if hrp then
        for _, child in pairs(hrp:GetChildren()) do
            local name = child.Name:lower()
            -- Chercher UNIQUEMENT les bulles vraiment nommées
            if name == "bubble" or name == "spawnbubble" or name == "shield" or name:find("^bubble") then
                if child:IsA("Part") or child:IsA("Model") then
                    return true
                end
            end
        end
    end
    
    -- Vérifier workspace.PLAYERNAME.ForceField
    if playerName then
        local playerFolder = Workspace:FindFirstChild(playerName)
        if playerFolder then
            local forceField = playerFolder:FindFirstChild("ForceField")
            if forceField then
                return true
            end
        end
    end
    
    return false
end

local function getTargetEnemy()
    local char = LocalPlayer.Character
    if not char then return nil end
    local localHRP = char:FindFirstChild("HumanoidRootPart")
    if not localHRP then return nil end

    local playerTeam = LocalPlayer.Team and LocalPlayer.Team.Name or "Neutral"
    local enemyTeams = {}
    
    if playerTeam == "Guards" then
        enemyTeams = { Dogs = true, StrayDogs = true }
    elseif playerTeam == "Dogs" or playerTeam == "StrayDogs" then
        enemyTeams = { Guards = true }
    else
        return nil
    end

    -- Check if focused player is valid and use them as priority target
    if aimbotFocusedPlayer and Players:FindFirstChild(aimbotFocusedPlayer) then
        local focusedPlr = Players:FindFirstChild(aimbotFocusedPlayer)
        if focusedPlr and focusedPlr.Character and focusedPlr.Team and enemyTeams[focusedPlr.Team.Name] then
            local pChar = focusedPlr.Character
            local isBlacklisted = Config.AimbotBlacklist and Config.AimbotBlacklist[tostring(focusedPlr.UserId)]
            
            if not isBlacklisted then
                local hasSpawn = hasSpawnBubble(pChar, focusedPlr.Name)
                if not hasSpawn then
                    local targetPart = pChar:FindFirstChild("Torso") or pChar:FindFirstChild("HumanoidRootPart")
                    local pHum = pChar:FindFirstChildOfClass("Humanoid")
                    
                    if targetPart and pHum and pHum.Health > 0 then
                        local dist = (targetPart.Position - localHRP.Position).Magnitude
                        local direction = (targetPart.Position - localHRP.Position).Unit
                        local params = RaycastParams.new()
                        params.FilterType = Enum.RaycastFilterType.Blacklist
                        params.FilterDescendantsInstances = {char}
                        local hit = workspace:Raycast(localHRP.Position, direction * dist, params)
                        
                        if not hit or hit.Instance:IsDescendantOf(pChar) then
                            return targetPart
                        end
                    end
                end
            end
        end
        -- If focused player is invalid, clear the focus
        aimbotFocusedPlayer = nil
    end

    local bestTarget = nil
    local bestValue = math.huge
    local mouse = LocalPlayer:GetMouse()

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            -- Vérifier les équipes seulement si Team Check est activé
            local isEnemyTeam = false
            if aimbotTeamCheck then
                if plr.Team and enemyTeams[plr.Team.Name] then
                    isEnemyTeam = true
                end
            else
                -- Si Team Check est désactivé, viser tout le monde (sauf LocalPlayer et blacklist)
                isEnemyTeam = true
            end
            
            if isEnemyTeam then
                -- Vérifier la blacklist
                local isBlacklisted = false
                if Config.AimbotBlacklist and Config.AimbotBlacklist[tostring(plr.UserId)] then
                    isBlacklisted = true
                end
                
                if not isBlacklisted then
                    local pChar = plr.Character
                    if pChar then
                        -- Vérifier si le joueur a une bulle d'apparition ou un ForceField
                        local hasSpawn = hasSpawnBubble(pChar, plr.Name)
                        
                        if not hasSpawn then
                            local targetPart = pChar:FindFirstChild("Torso")
                            local pHum = pChar:FindFirstChildOfClass("Humanoid")
                            
                            if not targetPart then
                                targetPart = pChar:FindFirstChild("HumanoidRootPart")
                            end
                            
                            if targetPart and pHum and pHum.Health > 0 then
                                local dist = (targetPart.Position - localHRP.Position).Magnitude
                                
                                local direction = (targetPart.Position - localHRP.Position).Unit
                                local params = RaycastParams.new()
                                params.FilterType = Enum.RaycastFilterType.Blacklist
                                params.FilterDescendantsInstances = {char}
                                local hit = workspace:Raycast(localHRP.Position, direction * dist, params)
                                
                                if not hit or hit.Instance:IsDescendantOf(pChar) then
                                    if aimbotTargetMode == "Nearest" then
                                        if dist < bestValue then
                                            bestValue = dist
                                            bestTarget = targetPart
                                        end
                                    elseif aimbotTargetMode == "Lowest" then
                                        local hp = pHum.Health
                                        if hp < bestValue then
                                            bestValue = hp
                                            bestTarget = targetPart
                                        end
                                    elseif aimbotTargetMode == "Mouse" then
                                        -- Mode Mouse: trouver le joueur le plus proche du curseur
                                        local screenPos = (workspace.CurrentCamera or game.Workspace.Camera):WorldToScreenPoint(targetPart.Position)
                                        local mouseScreenPos = Vector2.new(mouse.X, mouse.Y)
                                        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mouseScreenPos).Magnitude
                                        
                                        if screenDist < bestValue then
                                            bestValue = screenDist
                                            bestTarget = targetPart
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Hook souris (silent aim) — redirige Hit/Target vers la cible quand aimbot actif
local mouse    = LocalPlayer:GetMouse()
local oldIndex = nil

oldIndex = hookmetamethod(game, "__index", function(self, key)
    if self == mouse and not checkcaller() and aimbotEnabled then
        local target = getTargetEnemy()
        if target then
            if key == "Hit" then
                local pred = 0.165
                return target.CFrame + (target.Velocity * pred)
            elseif key == "Target" then
                return target
            end
        end
        -- Aucune cible → comportement souris normal (fall-through)
    end
    return oldIndex(self, key)
end)

-- ====== BLOQUEUR DE TIR SANS CIBLE ======
-- Principe :
--   • Au clic (InputBegan) : évaluer s'il y a une cible valide.
--       - Pas de cible → shouldBlockShot = true
--       - Cible trouvée → shouldBlockShot = false  (le tir part normalement)
--   • Dans __namecall (FireServer) : si shouldBlockShot, annuler l'appel et consommer le flag.
--   • Au relâchement (InputEnded) : réinitialiser le flag en sécurité.
--   ⚠ PAS de task.wait ici — cela crée une race condition et reset le flag trop tôt.
local shouldBlockShot = false

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 and aimbotEnabled then
        -- getTargetEnemy() utilise un cache 80 ms → appel quasi-gratuit
        local target = getTargetEnemy()
        -- Bloquer seulement quand il N'Y A PAS de cible visible
        shouldBlockShot = (target == nil)
    end
end)

-- Réinitialisation de sécurité au relâchement du bouton
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        shouldBlockShot = false
    end
end)

local oldNamecall = nil
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    -- Intercepter tout FireServer quand aimbot actif + flag de blocage levé
    if method == "FireServer" and aimbotEnabled and shouldBlockShot then
        shouldBlockShot = false   -- consommer le flag (1 seul blocage par clic)
        return nil                -- annuler le tir
    end
    return oldNamecall(self, ...)
end)

