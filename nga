    minimizeBtn.BorderSizePixel = 0
    minimizeBtn.Parent = header
    Instance.new("UICorner", minimizeBtn).CornerRadius = UDim.new(0, 6)

    -- État du collapsing
    local isCollapsed = Config.CollapsedPanels and Config.CollapsedPanels[panelKey] or false
    minimizeBtn.Text = isCollapsed and "+" or "−"
    
    -- Appliquer l'état initial
    if isCollapsed then
        frame.Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, headerHeight)
    end

    local function saveCollapsedState(collapsed)
        if not Config.CollapsedPanels then Config.CollapsedPanels = {} end
        Config.CollapsedPanels[panelKey] = collapsed
        SaveConfig()
    end

    local function toggleCollapse()
        isCollapsed = not isCollapsed
        
        -- Animer le redimensionnement du panel
        local tw = TweenService:Create(frame, 
            TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
            {Size = isCollapsed 
                and UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, headerHeight)
                or originalSize
            }
        )
        tw:Play()
        
        minimizeBtn.Text = isCollapsed and "+" or "−"
        saveCollapsedState(isCollapsed)
    end

    -- Gestion des clics
    minimizeBtn.MouseButton1Click:Connect(function()
        toggleCollapse()
    end)
    
    -- Rétroaction visuelle
    minimizeBtn.MouseEnter:Connect(function()
        minimizeBtn.BackgroundColor3 = Theme.Accent1
        minimizeBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    end)
    minimizeBtn.MouseLeave:Connect(function()
        minimizeBtn.BackgroundColor3 = Theme.SurfaceHighlight
        minimizeBtn.TextColor3 = Theme.TextPrimary
    end)
end

