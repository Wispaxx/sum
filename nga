local function ApplyTheme(themeName)
    local t = Themes[themeName]
    if not t then
        themeName = "Blue"
        t = Themes.Blue
    end

    local previousTheme = {}
    for k, v in pairs(Theme) do
        previousTheme[k] = v
    end

    Config.Theme = themeName
    SaveConfig()

    -- Update the global Theme table first so future UI uses the selected theme.
    for k, v in pairs(t) do
        Theme[k] = v
    end

    local legacyThemeColors = {
        { color = Color3.fromRGB(0, 225, 255), key = "Accent1" },
        { color = Color3.fromRGB(170, 0, 255), key = "Accent2" },
        { color = Color3.fromRGB(180, 0, 255), key = "Accent2" },
        { color = Color3.fromRGB(15, 15, 20), key = "Background" },
        { color = Color3.fromRGB(20, 22, 28), key = "Background" },
        { color = Color3.fromRGB(22, 22, 30), key = "Surface" },
        { color = Color3.fromRGB(25, 27, 35), key = "Surface" },
        { color = Color3.fromRGB(35, 35, 45), key = "SurfaceHighlight" },
        { color = Color3.fromRGB(35, 37, 43), key = "SurfaceHighlight" },
        { color = Color3.fromRGB(30, 30, 40), key = "SurfaceHighlight" },
        { color = Color3.fromRGB(10, 10, 20), key = "Background" },
        { color = Color3.fromRGB(240, 240, 240), key = "TextPrimary" },
        { color = Color3.fromRGB(235, 235, 245), key = "TextPrimary" },
        { color = Color3.fromRGB(140, 140, 150), key = "TextSecondary" },
        { color = Color3.fromRGB(130, 130, 145), key = "TextSecondary" },
        { color = Color3.fromRGB(255, 60, 80), key = "Error" },
        { color = Color3.fromRGB(255, 80, 80), key = "Error" },
        { color = Color3.fromRGB(255, 75, 55), key = "Error" },
    }

    local function colorsAreClose(a, b)
        if not a or not b then return false end
        return math.abs(a.R - b.R) < 0.01
            and math.abs(a.G - b.G) < 0.01
            and math.abs(a.B - b.B) < 0.01
    end

    local function themedColor(color)
        if not color then return nil end

        for key, oldColor in pairs(previousTheme) do
            if Theme[key] and colorsAreClose(color, oldColor) then
                return Theme[key]
            end
        end

        for _, entry in ipairs(legacyThemeColors) do
            if Theme[entry.key] and colorsAreClose(color, entry.color) then
                return Theme[entry.key]
            end
        end

        return nil
    end

    local function applyThemeColor(object, property)
        local ok, current = pcall(function()
            return object[property]
        end)
        if not ok then return end

        local newColor = themedColor(current)
        if newColor then
            pcall(function()
                object[property] = newColor
            end)
        end
    end

    local function applyThemedText(object)
        local textKey = object.Name:match("^TextKey_(.+)$")
        if textKey then
            if textKey == "PLAYERS_SECTION" then
                local expanded = object.Text:find("▼", 1, true) ~= nil
                object.Text = (expanded and "▼" or "▶") .. "  " .. ThemedText(textKey)
            else
                object.Text = ThemedText(textKey)
            end

        elseif object.Name == "ActionBtn" and (object.Text == "GIVE" or object.Text == "MEOW") then
            object.Text = ThemedText("GIVE_ACTION")
        end
    end

    local function applyFurryEar(object)
        if not object.Name:match("^FurryEar") then return end

        local isInner = object.Name:find("Inner", 1, true) ~= nil
        object.Visible = Config.Theme == "Furry"
        object.TextColor3 = isInner and Theme.Surface or Theme.Accent1
        object.TextStrokeColor3 = Theme.Accent2
        object.TextStrokeTransparency = isInner and 1 or 0.25
    end

    local function applyGradient(gradient)
        local changed = false
        local newKeypoints = {}

        for _, keypoint in ipairs(gradient.Color.Keypoints) do
            local newColor = themedColor(keypoint.Value)
            if newColor then
                changed = true
                table.insert(newKeypoints, ColorSequenceKeypoint.new(keypoint.Time, newColor))
            else
                table.insert(newKeypoints, keypoint)
            end
        end

        if changed then
            gradient.Color = ColorSequence.new(newKeypoints)
        end
    end

    -- Update existing UI: backgrounds, texts, images, strokes, scrollbars and gradients.
    local function sweep(parent)
        for _, desc in pairs(parent:GetDescendants()) do
            if desc:IsA("GuiObject") then
                applyThemeColor(desc, "BackgroundColor3")

                if desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox") then
                    applyThemeColor(desc, "TextColor3")
                    applyThemeColor(desc, "TextStrokeColor3")
                    applyThemedText(desc)
                    applyFurryEar(desc)
                end

                if desc:IsA("ImageLabel") or desc:IsA("ImageButton") then
                    applyThemeColor(desc, "ImageColor3")
                end
            end

            if desc:IsA("UIStroke") then
                applyThemeColor(desc, "Color")
            elseif desc:IsA("UIGradient") then
                applyGradient(desc)
            elseif desc:IsA("ScrollingFrame") then
                desc.ScrollBarImageColor3 = Theme.Accent1
            end
        end
    end

    for _, sg in pairs(PlayerGui:GetChildren()) do
        if sg:IsA("ScreenGui") then
            pcall(sweep, sg)
        end
    end
end

