            -- Désactiver visuellement le bouton (on utilise AutoButtonColor et on change l'apparence)
            hpLimitBtn.AutoButtonColor = false
            hpLimitBtn.BackgroundColor3 = Theme.SurfaceHighlight
            hpLimitBtn.Text = "Being Invincible, please wait..."
            
            -- Afficher la notification
            ShowNotification("Invincible", "Being Invincible, please wait...")
            
            -- Récupérer le prompt du Gear dans le Give Panel
            local gearPrompt = nil
            local gearPart = workspace:FindFirstChild("Map")
            if gearPart then
                gearPart = gearPart:FindFirstChild("GuardsRoom")
                if gearPart then
                    gearPart = gearPart:FindFirstChild("Important")
                    if gearPart then
                        gearPart = gearPart:FindFirstChild("SwatShelf")
                        if gearPart then
                            gearPart = gearPart:FindFirstChild("SwatShelfInteractive")
                            if gearPart then
                                gearPrompt = gearPart:FindFirstChildOfClass("ProximityPrompt")
                            end
                        end
                    end
                end
            end
            
            if not gearPrompt then
                ShowNotification("Invincible", "Failed to find Gear prompt!")
                hpLimitBtn.BackgroundColor3 = Theme.Accent2
                hpLimitBtn.Text = "Become Invincible"
                isProcessing = false
                return
            end
            
            -- Sauvegarder l'état du noclip
            local wasNoclipEnabled = noclipEnabled
            local oldCFrame = nil
            local startChar = LocalPlayer.Character
            local startHrp = startChar and startChar:FindFirstChild("HumanoidRootPart")
            if startHrp then
                oldCFrame = startHrp.CFrame
            end
            
            -- Activer noclip temporairement
            if not wasNoclipEnabled then
                setNoclip(true)
                task.wait(0.1)
            end
            
            -- Coordonnées du Gear
            local bodyCF = CFrame.new(1.10605025, 13.6199989, -138.175232, -0.00575545756, 6.77439829e-08, 0.99998343, -4.91059851e-08, 1, -6.8027731e-08, -0.99998343, -4.94967018e-08, -0.00575545756)
            
            -- TP vers le Gear
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = bodyCF
                    task.wait(0.3)
                end
            end
            
            -- Fire le prompt 10 fois avec intervalle de 1 seconde
            for i = 1, 15 do
                pcall(function()
                    fireproximityprompt(gearPrompt)
                end)
                pcall(function()
                    gearPrompt:InputHoldBegin()
                    task.wait(0.05)
                    gearPrompt:InputHoldEnd()
                end)
                
                -- Mettre à jour la notification pour montrer la progression
                if i < 15 then
                    ShowNotification("Invincible", "Invincible enabling... (" .. i .. "/15)")
                end
                
                task.wait(1) -- Attendre 1 seconde entre chaque fire
            end

            -- Retourner à l'ancienne position après la fin de l'invincible
            if oldCFrame then
                local returnChar = LocalPlayer.Character
                local returnHrp = returnChar and returnChar:FindFirstChild("HumanoidRootPart")
                if returnHrp then
                    returnHrp.CFrame = oldCFrame
                    task.wait(0.15)
                end
            end
            
            -- Désactiver noclip si nécessaire
            if not wasNoclipEnabled then
                setNoclip(false)
            end
            
            -- Notification de succès
            ShowNotification("Invincible", "Your successfully invincible!")
            
            -- Réactiver le bouton
            hpLimitBtn.BackgroundColor3 = Theme.Accent2
            hpLimitBtn.Text = "Be invincible"
            isProcessing = false
        end)
    end)
end

