    local flyKeys = { Forward = 0, Left = 0, Back = 0, Right = 0, Up = 0, Down = 0 }
    local flyKeyDownConn = nil
    local flyKeyUpConn = nil

    local function startFly()
        if flyActive then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end

        flyActive = true
        flyBodyGyro = Instance.new("BodyGyro")
        flyBodyGyro.P = 9e4
        flyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        flyBodyGyro.Parent = hrp

        flyBodyVelocity = Instance.new("BodyVelocity")
        flyBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        flyBodyVelocity.Parent = hrp

        hum.PlatformStand = true

        local function onKeyDown(input, processed)
            if processed then return end
            local key = input.KeyCode
            if key == Enum.KeyCode.W then flyKeys.Forward = 1
            elseif key == Enum.KeyCode.A then flyKeys.Left = 1
            elseif key == Enum.KeyCode.S then flyKeys.Back = 1
            elseif key == Enum.KeyCode.D then flyKeys.Right = 1
            elseif key == Enum.KeyCode.E then flyKeys.Up = 1
            elseif key == Enum.KeyCode.Q then flyKeys.Down = 1
            end
        end

        local function onKeyUp(input, processed)
            if processed then return end
            local key = input.KeyCode
            if key == Enum.KeyCode.W then flyKeys.Forward = 0
            elseif key == Enum.KeyCode.A then flyKeys.Left = 0
            elseif key == Enum.KeyCode.S then flyKeys.Back = 0
            elseif key == Enum.KeyCode.D then flyKeys.Right = 0
            elseif key == Enum.KeyCode.E then flyKeys.Up = 0
            elseif key == Enum.KeyCode.Q then flyKeys.Down = 0
            end
        end

        flyKeyDownConn = UserInputService.InputBegan:Connect(onKeyDown)
        flyKeyUpConn = UserInputService.InputEnded:Connect(onKeyUp)

        local flyStepConn = RunService.Stepped:Connect(function()
            if not flyActive then return end
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then return end
            local camera = workspace.CurrentCamera
            local move = Vector3.new(flyKeys.Right - flyKeys.Left, flyKeys.Up - flyKeys.Down, flyKeys.Forward - flyKeys.Back)
            if move.Magnitude > 0 then
                local cf = camera.CFrame
                local vel = cf.RightVector * move.X + cf.UpVector * move.Y + cf.LookVector * move.Z
                flyBodyVelocity.Velocity = vel.Unit * FLY_SPEED * 50
            else
                flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end
            flyBodyGyro.CFrame = camera.CFrame
            hum.PlatformStand = true
        end)

        flyConnections = { flyStepConn, flyKeyDownConn, flyKeyUpConn,
            LocalPlayer.CharacterAdded:Connect(function()
                task.wait(0.5)
                if flyEnabled then startFly() end
            end)
        }
    end

    local function stopFly()
        flyActive = false
        for _, conn in pairs(flyConnections) do pcall(function() conn:Disconnect() end) end
        flyConnections = {}
