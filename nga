            end
            
            -- Soigner le coéquipier si trouvé ET qu'on n'a pas encore utilisé de MedKit cette session
            if nearestTeammate and not activeTeammateHealing and not medkitGrabbedForTeammate then
                activeTeammateHealing = true
                
                local targetChar = nearestTeammate.Character
                local targetHum = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
                
                if targetHum and targetHum.Health > 0 then
                    ShowNotification("Heal Teammate", "Healing " .. nearestTeammate.Name .. " (distance: " .. math.floor(nearestDist) .. " studs)")
                    
                    -- 1. Donner un MedKit si besoin
                    if not giveMedkitForTeammate() then
                        ShowNotification("Heal Teammate", "Failed to get MedKit!")
                        activeTeammateHealing = false
                        continue
                    end
                    
                    task.wait(0.2)
                    
                    -- 2. Récupérer le MedKit
                    local medkit = char:FindFirstChild("MedKit") or LocalPlayer.Backpack:FindFirstChild("MedKit")
                    
                    if medkit then
                        -- Sauvegarder l'outil actuel
                        local currentTool = char:FindFirstChildWhichIsA("Tool")
                        
                        -- Équiper le MedKit
                        if medkit.Parent ~= char then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hum then hum:EquipTool(medkit) end
                            task.wait(0.2)
                        end
                        
                        -- Soigner le coéquipier (fire le remote sur lui)
                        for i = 1, 3 do
                            pcall(function() 
                                MedKitRemote:FireServer(true, targetChar) 
                            end)
                            task.wait(0.1)
                        end
                        
                        -- Déséquiper
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then hum:UnequipTools() end
                        
                        -- Jeter le MedKit
                        dropMedKitTeammate()
                        
                        -- Marquer qu'on a utilisé un MedKit cette session
                        medkitGrabbedForTeammate = true
                        
                        -- Remettre l'ancien outil
                        if currentTool and currentTool ~= medkit then
                            task.wait(0.1)
                            if hum then hum:EquipTool(currentTool) end
                        end
                        
                        ShowNotification("Heal Teammate", nearestTeammate.Name .. " healed!")
                    end
                end
                
                activeTeammateHealing = false
                task.wait(1)
            end
        end
    end)
end

