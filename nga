-- ====== IMPROVED GRAB ITEM WITH RETRY LOGIC ======
local function grabItem(promptSource, itemName, customBodyCFrame, customCameraCFrame, maxRetries)
    maxRetries = maxRetries or 3
    
    for attempt = 1, maxRetries do
        local grabbedItem = nil
        local success = true
        
        pcall(function()
            local char = LocalPlayer.Character
            if not char then error("No character") end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then error("No HumanoidRootPart") end

            local savedBodyCFrame = hrp.CFrame
            local savedCameraCFrame = workspace.CurrentCamera and workspace.CurrentCamera.CFrame
            local wasNoclip = noclipEnabled

            if not wasNoclip then
                setNoclip(true)
                task.wait()
            end

            local prompt = promptSource
            if not prompt:IsA("ProximityPrompt") then
                prompt = findPromptInDescendants(promptSource)
            end
            if not prompt then
                error("Prompt not found for " .. itemName)
            end

            local targetPart = prompt.Parent
            if not targetPart or not targetPart:IsA("BasePart") then
                error("Target part not found")
            end

            -- Save current inventory
            local oldTools = {}
            for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                if tool:IsA("Tool") then oldTools[tool.Name] = true end
            end
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then oldTools[tool.Name] = true end
            end

            if customBodyCFrame then
                hrp.CFrame = customBodyCFrame
            else
                local targetPos = targetPart.Position
                local direction = (hrp.Position - targetPos).Unit
                local offset = direction * -5
                hrp.CFrame = CFrame.new(targetPos + offset) * CFrame.Angles(0, hrp.Orientation.Y, 0)
            end

            if not IS_MOBILE and customCameraCFrame and workspace.CurrentCamera then
                workspace.CurrentCamera.CFrame = customCameraCFrame
            end

            task.wait(0.05)

            -- Fire prompt multiple times
            for i = 1, 3 do
                pcall(function() fireproximityprompt(prompt) end)
                pcall(function() prompt:InputHoldBegin() task.wait(0.01) prompt:InputHoldEnd() end)
                task.wait(0.02)
            end

            -- Wait for item (max 1.5 seconds)
            local timeout = 1.5
            local startTime = tick()
            
            repeat
                task.wait(0.05)
                -- Check Backpack
                for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if tool:IsA("Tool") and not oldTools[tool.Name] then
                        grabbedItem = tool.Name
                        break
                    end
                end
                -- Check Character
                if not grabbedItem then
                    for _, tool in pairs(char:GetChildren()) do
                        if tool:IsA("Tool") and not oldTools[tool.Name] then
                            grabbedItem = tool.Name
                            break
                        end
                    end
                end
            until grabbedItem or tick() - startTime > timeout

            hrp.CFrame = savedBodyCFrame * CFrame.new(0, 3, 0)

            if not IS_MOBILE and savedCameraCFrame and workspace.CurrentCamera then
                workspace.CurrentCamera.CFrame = savedCameraCFrame
            end

            if not wasNoclip then
                setNoclip(false)
            end
        end)
        
        if grabbedItem then
            ShowNotification(ThemedText("GIVE_PANEL"), itemName .. " obtained! (Attempt " .. attempt .. ")")
            return true
        else
            if attempt < maxRetries then
                ShowNotification(ThemedText("GIVE_PANEL"), "Retry " .. attempt .. "/" .. maxRetries .. " for " .. itemName .. "...")
                task.wait(0.5)
                -- Slight position offset for retry
                if customBodyCFrame and attempt > 1 then
                    customBodyCFrame = customBodyCFrame + Vector3.new(
                        (math.random() - 0.5) * 2,
                        (math.random() - 0.5) * 1,
                        (math.random() - 0.5) * 2
                    )
                end
            end
        end
    end
    
    ShowNotification(ThemedText("GIVE_PANEL"), "Failed to get " .. itemName .. " after " .. maxRetries .. " attempts!")
    return false
end

