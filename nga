local autoReloadEnabled = false
local autoReloadConnection = nil
local autoReloadWatchedTools = {}

local function setAutoReload(enabled)
    autoReloadEnabled = enabled
    Config.AutoReload = enabled
    SaveConfig()
    
    if autoReloadConnection then
        autoReloadConnection:Disconnect()
        autoReloadConnection = nil
    end
    
    -- Clear watched tools
    autoReloadWatchedTools = {}
    
    if not enabled then return end

    -- Surveille les munitions d'ANY outil qui a une propriété "Ammo"
    local function watchTool(tool)
        if not tool or not tool:IsA("Tool") then return end
        if autoReloadWatchedTools[tool] then return end -- Déjà surveillé
        
        local ammo = tool:FindFirstChild("Ammo")
        local isReloading = tool:FindFirstChild("IsReloading")
        
        if not ammo or not isReloading then return end
        
        autoReloadWatchedTools[tool] = true
        
        local toolName = tool.Name:lower()
        
        ammo:GetPropertyChangedSignal("Value"):Connect(function()
            if ammo.Value == 0 and autoReloadEnabled and not isReloading.Value then
                -- Essayer tous les types de reload possibles
                
                -- Pour Rifle
                if toolName:find("rifle") then
                    pcall(function()
                        local rifleReload = game:GetService("ReplicatedStorage")
                            :FindFirstChild("RemoteEvents")
                        if rifleReload then
                            rifleReload = rifleReload:FindFirstChild("Weapons")
                            if rifleReload then
                                rifleReload = rifleReload:FindFirstChild("RifleReload")
                                if rifleReload then
                                    rifleReload:FireServer()
                                end
                            end
                        end
                    end)
                end
                
                -- Pour AK47
                if toolName:find("ak") then
                    pcall(function()
                        local playerName = LocalPlayer.Name
                        local ak47Reload = game:GetService("ReplicatedStorage")
                            :FindFirstChild("RemoteEvents")
                        if ak47Reload then
                            ak47Reload = ak47Reload:FindFirstChild("PlayerWeaponRemotes")
                            if ak47Reload then
                                ak47Reload = ak47Reload:FindFirstChild(playerName)
                                if ak47Reload then
                                    ak47Reload = ak47Reload:FindFirstChild("AK47Reload")
                                    if ak47Reload then
                                        ak47Reload:FireServer()
                                    end
                                end
                            end
                        end
                    end)
                end
                
                -- Pour autres armes (shotgun, MP5, taser, etc.)
                pcall(function()
                    local playerName = LocalPlayer.Name
                    local replicatedStorage = game:GetService("ReplicatedStorage")
                    
                    -- Essayer PlayerWeaponRemotes/[PlayerName]/[ToolName]Reload
                    local playerWeaponRemotes = replicatedStorage:FindFirstChild("RemoteEvents")
                    if playerWeaponRemotes then
                        playerWeaponRemotes = playerWeaponRemotes:FindFirstChild("PlayerWeaponRemotes")
                        if playerWeaponRemotes then
                            playerWeaponRemotes = playerWeaponRemotes:FindFirstChild(playerName)
                            if playerWeaponRemotes then
                                local reloadRemote = playerWeaponRemotes:FindFirstChild(tool.Name .. "Reload")
                                if reloadRemote then
                                    reloadRemote:FireServer()
                                end
                            end
                        end
                    end
                end)
            end
        end)
    end

    local function connectAmmoWatch()
        local char = LocalPlayer.Character
        if not char then return end
        
        -- Watch tous les outils actuels
        for _, tool in pairs(char:GetChildren()) do
            watchTool(tool)
        end
        
        -- Watch nouveaux outils équipés
        local charChildConn = char.ChildAdded:Connect(function(child)
            watchTool(child)
        end)
        
        -- Watch backpack
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            local bpChildConn = bp.ChildAdded:Connect(function(child)
                watchTool(child)
            end)
        end
    end

    connectAmmoWatch()
    autoReloadConnection = LocalPlayer.CharacterAdded:Connect(function()
        autoReloadWatchedTools = {}
        task.wait(0.3) -- Délai réduit de 0.5 à 0.3 pour plus de rapidité
        connectAmmoWatch()
    end)
end

