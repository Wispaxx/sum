end

local function ESP(plr)
    task.spawn(function()
        for _, v in pairs(CoreGui:GetChildren()) do
            if v.Name == plr.Name .. "_ESP_DB" then v:Destroy() end
        end
        task.wait()
        -- Après :
        if not plr.Character or plr.Name == LocalPlayer.Name then return end

        -- Filtre par team
        local teamName = plr.Team and plr.Team.Name or ""
        local filtered = false
        if not Config.EspTeamFilter then Config.EspTeamFilter = { Stray = true, Dogs = true, Guards = true } end
        if teamName == "StrayDogs" and not Config.EspTeamFilter.Stray then filtered = true end
        if teamName == "Dogs"      and not Config.EspTeamFilter.Dogs   then filtered = true end
        if teamName == "Guards"    and not Config.EspTeamFilter.Guards  then filtered = true end
        
        -- CORRECTION : Si filtré, on retourne simplement sans essayer de détruire ESPholder (qui n'existe pas encore)
        if filtered then 
            return 
        end
        
        if CoreGui:FindFirstChild(plr.Name .. "_ESP_DB") then return end

        local ESPholder = Instance.new("Folder")
        ESPholder.Name = plr.Name .. "_ESP_DB"
        ESPholder.Parent = CoreGui

        repeat task.wait(0.5) until plr.Character
            and plr.Character:FindFirstChildOfClass("Humanoid")
            and plr.Character:FindFirstChild("Head")

        local char = plr.Character
        if not char then ESPholder:Destroy() return end

        local hl = Instance.new("Highlight")
        hl.Name = "HL_" .. plr.Name
        hl.Adornee = char
        hl.FillColor = espColor(plr)
        hl.FillTransparency = 0.65
        hl.OutlineColor = espColor(plr)
        hl.OutlineTransparency = 0.65
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = ESPholder

        local billboard = Instance.new("BillboardGui")
        billboard.Adornee = char:FindFirstChild("Head")
        billboard.Name = "BB_" .. plr.Name
        billboard.Parent = ESPholder
        billboard.Size = UDim2.new(0, 100, 0, 44)
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.AlwaysOnTop = true

        local lbl = Instance.new("TextLabel")
        lbl.Parent = billboard
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.Font = Enum.Font.SourceSansSemibold
        lbl.TextSize = 14
        lbl.TextColor3 = Color3.new(1, 1, 1)
        lbl.TextStrokeTransparency = 0
        lbl.TextWrapped = true
        lbl.Text = plr.Name

        local loopConn, addedConn, teamConn

        local function stopESP()
            if loopConn then loopConn:Disconnect() end
            if addedConn then addedConn:Disconnect() end
            if teamConn then teamConn:Disconnect() end
            if ESPholder and ESPholder.Parent then ESPholder:Destroy() end
        end

        local function restartESP()
            stopESP()
            if espEnabled then
                task.wait(0.5)
                ESP(plr)
            end
        end

        addedConn = plr.CharacterAdded:Connect(restartESP)
        teamConn  = plr:GetPropertyChangedSignal("TeamColor"):Connect(restartESP)

        loopConn = RunService.RenderStepped:Connect(function()
            if not CoreGui:FindFirstChild(plr.Name .. "_ESP_DB") then
                stopESP()
                return
            end
            local c = plr.Character
            if c and c:FindFirstChildOfClass("Humanoid") then
                local hum = c:FindFirstChildOfClass("Humanoid")
                local hp = roundHp(hum.Health)
                lbl.Text = plr.Name .. "\n" .. hp
                local col = espColor(plr)
                hl.FillColor    = col
                hl.OutlineColor = col
            end
        end)
    end)
