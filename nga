local GIVE_GAMEPASS_VET   = 1799595201  -- Required for: MP5, SAW, Shock Gun
local GIVE_GAMEPASS_SWAT  = 1803314217  -- Required for: M4A1, Gear
local GIVE_GAMEPASS_STRAY = 1799827363  -- Required for: Key Card, AK47

-- Items that require a gamepass (key = item label key, value = gamepass id)
local GIVE_GAMEPASS_REQUIREMENTS = {
    ShockGun = GIVE_GAMEPASS_VET,
    MP5      = GIVE_GAMEPASS_VET,
    SAW      = GIVE_GAMEPASS_VET,
    M4A1     = GIVE_GAMEPASS_SWAT,
    Gear     = GIVE_GAMEPASS_SWAT,
    KeyCard  = GIVE_GAMEPASS_STRAY,
    AK47     = GIVE_GAMEPASS_STRAY,
}

local GIVE_GAMEPASS_NAMES = {
    [GIVE_GAMEPASS_VET]   = "Vet Gamepass",
    [GIVE_GAMEPASS_SWAT]  = "SWAT Gamepass",
    [GIVE_GAMEPASS_STRAY] = "Stray Gamepass",
}

local MarketplaceService = game:GetService("MarketplaceService")

-- Cache to avoid too many network calls
local gamepassCache = {}
local function hasGamepass(gamepassId)
    if gamepassCache[gamepassId] ~= nil then
        return gamepassCache[gamepassId]
    end
    local owned = false
    pcall(function()
        owned = MarketplaceService:UserOwnsGamePassAsync(LocalPlayer.UserId, gamepassId)
    end)
    gamepassCache[gamepassId] = owned
    return owned
end

-- Returns the required gamepass id for a given button label, or nil if none required
local function getRequiredGamepass(label)
    for itemKey, passId in pairs(GIVE_GAMEPASS_REQUIREMENTS) do
        if GetText(itemKey) == label then
            return passId
        end
    end
    return nil
end
-- ====== END GIVE PANEL GAMEPASS ======

local function CreateGiveButton(parent, label, giveAction)
    local gRow = Instance.new("Frame", parent)
    gRow.Size = UDim2.new(1, 0, 0, 50)
    gRow.BackgroundColor3 = Theme.Surface
    gRow.BorderSizePixel = 0
    gRow.LayoutOrder = giveButtonIndex
    giveButtonIndex = giveButtonIndex + 1
    Instance.new("UICorner", gRow).CornerRadius = UDim.new(0, 8)

    local gLabel = Instance.new("TextLabel", gRow)
    gLabel.Size = UDim2.new(0.6, 0, 1, 0)
    gLabel.Position = UDim2.new(0, 12, 0, 0)
    gLabel.BackgroundTransparency = 1
    gLabel.Text = label
    gLabel.Font = Enum.Font.GothamMedium
    gLabel.TextSize = 13
    gLabel.TextColor3 = Theme.TextPrimary
    gLabel.TextXAlignment = Enum.TextXAlignment.Left

    local gvBtn = Instance.new("TextButton", gRow)
    gvBtn.Name = "ActionBtn"
    gvBtn.Size = UDim2.new(0, IS_MOBILE and 66 or 56, 0, IS_MOBILE and 36 or 30)
    gvBtn.Position = UDim2.new(1, IS_MOBILE and -76 or -66, 0.5, IS_MOBILE and -18 or -15)
    gvBtn.BackgroundColor3 = Theme.Accent1
    gvBtn.Text = ThemedText("GIVE_ACTION")
    gvBtn.Font = Enum.Font.GothamBlack
    gvBtn.TextSize = IS_MOBILE and 12 or 11
    gvBtn.TextColor3 = Theme.Background
    gvBtn.AutoButtonColor = false
    Instance.new("UICorner", gvBtn).CornerRadius = UDim.new(0, 8)

    gvBtn.MouseEnter:Connect(function()
        TweenService:Create(gvBtn, TweenInfo.new(0.2), {BackgroundTransparency = 0.2}):Play()
    end)
    gvBtn.MouseLeave:Connect(function()
        TweenService:Create(gvBtn, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
    end)

    gvBtn.MouseButton1Click:Connect(function()
        -- ====== GIVE PANEL GAMEPASS CHECK ======
        local requiredPassId = getRequiredGamepass(label)
        if requiredPassId then
            if not hasGamepass(requiredPassId) then
                local passName = GIVE_GAMEPASS_NAMES[requiredPassId] or ("Gamepass #" .. tostring(requiredPassId))
                ShowNotification("Gamepass Required", label .. " requires the " .. passName .. ".")
                return
            end
        end
        -- ====== END GIVE PANEL GAMEPASS CHECK ======

        -- AUTO GRAB ONLY ACTIVE DURING GIVE PANEL
        -- Activer AutoGrab s'il n'est pas déjà actif
        setAutoGrab(true, true) -- true = enabled, true = only during give panel
        task.wait(0.1)
        
        local ok, err = pcall(giveAction)
        if ok then
            ShowNotification(ThemedText("GIVE_PANEL"), label .. " " .. GetText("OBTAINED"))
        else
            ShowNotification(ThemedText("GIVE_PANEL"), "Error: " .. tostring(err))
        end
        
        -- Désactiver AutoGrab après l'action du give panel
        task.wait(0.2)
        setAutoGrab(false, true) -- false = disabled, true = only during give panel
    end)
    
    return gRow
end

