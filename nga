-- ====== AUTO GRAB ======
local BLOCKED_GRANDPARENTS = {
    "TakeMP5Table",
    "TakeShockGunTable",
    "Radio1",
    "Radio2",
    "Radio3",
    "Radio4",
    "Radio5",
    "Radio6",
