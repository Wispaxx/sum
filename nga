-- ====== HP HUD (en haut à droite, suppression de la barre par défaut) ======
task.spawn(function()
    -- Attendre que le joueur ait un personnage
    repeat task.wait() until LocalPlayer.Character
    
    -- ====== SUPPRESSION DE LA BARRE DE VIE PAR DÉFAUT ======
    local function isCustomHudObject(obj)
        local current = obj
        while current do
            if current.Name == "XiStatusHUD" or current.Name == "XiHPHUD" or current.Name == "HPContainer" then
                return true
            end
            current = current.Parent
        end
        return false
    end

    local function removeDefaultHealthBar()
        -- Méthode 1: Chercher dans PlayerGui
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            -- Chercher les éléments typiques de barre de vie
            for _, child in pairs(playerGui:GetDescendants()) do
                if (child:IsA("Frame") or child:IsA("ImageLabel")) and not isCustomHudObject(child) then
                    local name = child.Name:lower()
                    -- Détection par nom
                    if name:find("health") or name:find("hp") or name:find("life") or 
                       name:find("healthbar") or name:find("status") or name:find("hud") then
                        -- Vérifier si c'est une barre de vie (taille horizontale caractéristique)
                        if child:IsA("Frame") and child.Size.Y.Offset < 20 and child.Size.X.Offset > 30 then
                            pcall(function() child.Visible = false end)
                            pcall(function() child.Enabled = false end)
                        end
                    end
                end
            end
        end
        
        -- Méthode 2: Chercher dans CoreGui (UI système)
        local coreGui = game:GetService("CoreGui")
        if coreGui then
            for _, child in pairs(coreGui:GetDescendants()) do
                if child:IsA("Frame") or child:IsA("ImageLabel") then
                    local name = child.Name:lower()
                    if name:find("health") or name:find("hp") or name:find("life") or 
                       name:find("healthbar") then
                        pcall(function() child.Visible = false end)
                    end
                end
            end
        end
        
        -- Méthode 3: Chercher dans le StarterGui (pour empêcher la recréation)
        local starterGui = game:GetService("StarterGui")
        if starterGui then
            for _, child in pairs(starterGui:GetDescendants()) do
                if child:IsA("Frame") or child:IsA("ImageLabel") then
                    local name = child.Name:lower()
                    if name:find("health") or name:find("hp") then
                        pcall(function() child.Visible = false end)
                    end
                end
            end
        end
    end
    
    -- Supprimer immédiatement
    removeDefaultHealthBar()
    
    -- Surveiller les nouvelles UI qui pourraient apparaître
    local function watchForHealthBar()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if not playerGui then return end
        
        local connection
        connection = playerGui.DescendantAdded:Connect(function(descendant)
            if (descendant:IsA("Frame") or descendant:IsA("ImageLabel")) and not isCustomHudObject(descendant) then
                local name = descendant.Name:lower()
                if name:find("health") or name:find("hp") or name:find("life") then
                    task.wait(0.1)
                    if not isCustomHudObject(descendant) then
                        pcall(function() 
                            descendant.Visible = false
                        end)
                    end
                end
            end
        end)
        
        -- Nettoyer la connexion après 10 secondes (plus besoin)
        task.delay(10, function()
            if connection then connection:Disconnect() end
        end)
    end
    
    task.spawn(watchForHealthBar)
    
    -- ====== CRÉATION DU HUD HP PERSONNALISÉ ======
    local statusHud, statusMain, statusTopBar
    if not IS_MOBILE then
        statusHud = PlayerGui:FindFirstChild("XiStatusHUD") or PlayerGui:WaitForChild("XiStatusHUD", 5)
        statusMain = statusHud and (statusHud:FindFirstChild("Main") or statusHud:WaitForChild("Main", 2))
        statusTopBar = statusMain and (statusMain:FindFirstChild("TopBar") or statusMain:WaitForChild("TopBar", 2))
    end

    local oldHpGui = PlayerGui:FindFirstChild("XiHPHUD")
    if oldHpGui then oldHpGui:Destroy() end
    local oldHpContainer = statusTopBar and statusTopBar:FindFirstChild("HPContainer")
    if oldHpContainer then
        oldHpContainer:Destroy()
    end

    local attachToDogPoundHud = (not IS_MOBILE) and statusHud ~= nil and statusMain ~= nil and statusTopBar ~= nil
    local hpGui = nil

    if attachToDogPoundHud then
        -- Agrandit légèrement le HUD Dog Pound et décale FPS/PING pour faire une vraie place aux HP.
        statusMain.Size = UDim2.new(0, 620, statusMain.Size.Y.Scale, statusMain.Size.Y.Offset)
        local statsContainer = statusTopBar:FindFirstChild("StatsContainer")
        if statsContainer then
            statsContainer.Size = UDim2.new(0, 190, 1, 0)
            statsContainer.Position = UDim2.new(1, -20, 0, 0)
        end
    else
        hpGui = Instance.new("ScreenGui")
        hpGui.Name = "XiHPHUD"
        hpGui.ResetOnSpawn = false
        hpGui.Parent = PlayerGui
        hpGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        hpGui.DisplayOrder = 999
    end

    local TextService = game:GetService("TextService")
    local minHpWidth = IS_MOBILE and 108 or 118
    local maxHpWidth = IS_MOBILE and 178 or 230
    local baseDogPoundHudWidth = 620
    local hpWidth = minHpWidth
    local hpHeight = IS_MOBILE and 36 or 38
    local hpIconSize = IS_MOBILE and 18 or 22
    local hpTextNormalSize = IS_MOBILE and 13 or 15
    local hpTextPulseSize = hpTextNormalSize + 2
    local hpBarHeight = IS_MOBILE and 4 or 5
    local mobileHpY = -28
    local container

    local function resizeHpHudForText(text)
        local textSize = TextService:GetTextSize(text, hpTextNormalSize, Enum.Font.GothamBlack, Vector2.new(1000, hpHeight))
        local wantedWidth = math.clamp(math.ceil(textSize.X + hpIconSize + 32), minHpWidth, maxHpWidth)
        hpWidth = wantedWidth
        container.Size = UDim2.new(0, hpWidth, 0, hpHeight)

        if attachToDogPoundHud then
            local extraWidth = math.max(0, hpWidth - minHpWidth)
            statusMain.Size = UDim2.new(0, baseDogPoundHudWidth + extraWidth, statusMain.Size.Y.Scale, statusMain.Size.Y.Offset)
        else
            container.Position = UDim2.new(1, -(hpWidth + 10), 0, IS_MOBILE and mobileHpY or 20)
        end
    end

    container = Instance.new("Frame")
    container.Name = "HPContainer"
    container.Size = UDim2.new(0, hpWidth, 0, hpHeight)
    if attachToDogPoundHud then
        container.Position = UDim2.new(1, -222, 0.5, 0)
        container.AnchorPoint = Vector2.new(1, 0.5)
        container.Parent = statusTopBar
    else
        container.Position = UDim2.new(1, -(hpWidth + 10), 0, IS_MOBILE and mobileHpY or 20)
        container.Parent = hpGui
    end
    container.BackgroundTransparency = 1
    
    -- Arrière-plan avec effet glass
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Theme.Background
    bg.BackgroundTransparency = 0.2
    bg.BorderSizePixel = 0
    bg.Parent = container
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, IS_MOBILE and 10 or 12)
    
    -- Bordure
    local stroke = Instance.new("UIStroke", bg)
    stroke.Thickness = IS_MOBILE and 1 or 1.5
    stroke.Transparency = 0.35
    
    -- Dégradé pour la bordure
    local strokeGrad = Instance.new("UIGradient", stroke)
    strokeGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Theme.Accent1),
        ColorSequenceKeypoint.new(1, Theme.Accent2)
    }
    strokeGrad.Rotation = 45
    
    -- Ombre portée légère
    local shadow = Instance.new("UICorner", container)
    shadow.CornerRadius = UDim.new(0, IS_MOBILE and 10 or 12)
    
    -- Barre de progression HP (en bas du container)
    local hpBarBg = Instance.new("Frame")
    hpBarBg.Size = UDim2.new(1, -14, 0, hpBarHeight)
    hpBarBg.Position = UDim2.new(0, 7, 1, -(IS_MOBILE and 8 or 9))
    hpBarBg.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    hpBarBg.BorderSizePixel = 0
    hpBarBg.Parent = container
    Instance.new("UICorner", hpBarBg).CornerRadius = UDim.new(1, 0)
    
    local hpBarFill = Instance.new("Frame")
    hpBarFill.Size = UDim2.new(1, 0, 1, 0)
    hpBarFill.BackgroundColor3 = Theme.Accent1
    hpBarFill.BorderSizePixel = 0
    hpBarFill.Parent = hpBarBg
    Instance.new("UICorner", hpBarFill).CornerRadius = UDim.new(1, 0)
    
    -- Icône ❤️
    local hpIcon = Instance.new("TextLabel")
    hpIcon.Size = UDim2.new(0, hpIconSize, 0, hpIconSize)
    hpIcon.Position = UDim2.new(0, 8, 0, IS_MOBILE and 5 or 6)
    hpIcon.BackgroundTransparency = 1
    hpIcon.Text = "❤️"
    hpIcon.Font = Enum.Font.GothamBold
    hpIcon.TextSize = hpIconSize
    hpIcon.TextColor3 = Color3.fromRGB(255, 70, 90)
    hpIcon.TextXAlignment = Enum.TextXAlignment.Center
    hpIcon.Parent = container
    
    -- Texte HP (nombre)
    local hpText = Instance.new("TextLabel")
    hpText.Size = UDim2.new(1, -(hpIconSize + 18), 0, hpHeight - hpBarHeight - 6)
    hpText.Position = UDim2.new(0, hpIconSize + 14, 0, 1)
    hpText.BackgroundTransparency = 1
    hpText.Text = "HP 100/100"
    hpText.Font = Enum.Font.GothamBlack
    hpText.TextSize = hpTextNormalSize
    hpText.TextColor3 = Theme.TextPrimary
    hpText.TextXAlignment = Enum.TextXAlignment.Left
    hpText.TextYAlignment = Enum.TextYAlignment.Center
    hpText.Parent = container
    
    -- Effet de scintillement léger sur le texte
    local glow = Instance.new("UIGradient", hpText)
    glow.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(0.5, Theme.Accent1),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
    }
    glow.Transparency = NumberSequence.new(0.5)
    glow.Rotation = 30
    
    -- Animation de pulsation du dégradé
    task.spawn(function()
        local direction = 1
        while hpText.Parent do
            task.wait(2.5)
            local newRot = glow.Rotation + direction * 12
            if newRot > 55 then direction = -1
            elseif newRot < 5 then direction = 1 end
            TweenService:Create(glow, TweenInfo.new(1.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Rotation = newRot}):Play()
        end
    end)
    
    -- Animation de changement de couleur selon % HP
    local function updateHpColor(percent)
        local r, g
        if percent > 70 then
            r, g = 80, 255
        elseif percent > 35 then
            r, g = 255, 180
        else
            r, g = 255, 60
        end
        hpBarFill.BackgroundColor3 = Color3.fromRGB(r, g, 60)
        hpText.TextColor3 = Color3.fromRGB(r, g, 200)
    end
    
    -- Mise à jour des HP
    local lastHp = -1
    local lastMaxHp = -1
    
    local function updateHP()
        local char = LocalPlayer.Character
        if not char then return end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        
        local currentHp = math.floor(hum.Health + 0.5)
        local maxHp = hum.MaxHealth
        
        if currentHp ~= lastHp or maxHp ~= lastMaxHp then
            lastHp = currentHp
            lastMaxHp = maxHp
            
            local hpLabel = "HP " .. tostring(currentHp) .. "/" .. tostring(math.floor(maxHp + 0.5))
            hpText.Text = hpLabel
            resizeHpHudForText(hpLabel)
            
            local percent = currentHp / math.max(maxHp, 1)
            local barWidth = math.clamp(percent, 0, 1)
            hpBarFill.Size = UDim2.new(barWidth, 0, 1, 0)
            
            updateHpColor(percent * 100)
            
            -- Effet visuel quand les HP changent
            local pulse = TweenService:Create(hpText, TweenInfo.new(0.08), {TextSize = hpTextPulseSize})
            pulse:Play()
            pulse.Completed:Connect(function()
                TweenService:Create(hpText, TweenInfo.new(0.08), {TextSize = hpTextNormalSize}):Play()
            end)
            
            -- Faire clignoter la barre si HP bas
            if percent < 0.3 then
                local originalColor = hpBarFill.BackgroundColor3
                TweenService:Create(hpBarFill, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(255, 100, 100)}):Play()
                task.wait(0.15)
                TweenService:Create(hpBarFill, TweenInfo.new(0.15), {BackgroundColor3 = originalColor}):Play()
            end
        end
    end
    
    -- Surveiller les changements de HP
    local hpConnection = nil
    local maxHpConnection = nil
    local function startHpMonitoring()
        local char = LocalPlayer.Character
        if not char then return end
        
        local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5)
        if not hum then return end
        
        if hpConnection then
            hpConnection:Disconnect()
            hpConnection = nil
        end
        if maxHpConnection then
            maxHpConnection:Disconnect()
            maxHpConnection = nil
        end

        lastHp = -1
        lastMaxHp = -1
        
        updateHP()
        
        hpConnection = hum:GetPropertyChangedSignal("Health"):Connect(updateHP)
        maxHpConnection = hum:GetPropertyChangedSignal("MaxHealth"):Connect(updateHP)

        task.delay(0.75, function()
            if hum.Parent then
                lastHp = -1
                lastMaxHp = -1
                updateHP()
            end
        end)
    end
    
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.3)
        startHpMonitoring()
        removeDefaultHealthBar()
    end)
    
    startHpMonitoring()
    -- Appliquer le thème dynamique
    local function applyThemeToHp()
        bg.BackgroundColor3 = Theme.Background
        stroke.Color = Theme.Accent2
        strokeGrad.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, Theme.Accent1),
            ColorSequenceKeypoint.new(1, Theme.Accent2)
        }
        updateHpColor((lastHp / math.max(lastMaxHp, 1)) * 100)
    end
    
    -- Étendre ApplyTheme pour inclure le HUD HP
    local originalApplyTheme = ApplyTheme
    ApplyTheme = function(themeName)
        originalApplyTheme(themeName)
        applyThemeToHp()
    end
    
    applyThemeToHp()
end)

