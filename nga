        local ov = CreateReorderOverlay(b, -10,
            function()
                local all = getQBtns()
                for i, x in ipairs(all) do
                    if x == captB and i > 1 then
                        local lo = captB.LayoutOrder
                        captB.LayoutOrder = all[i-1].LayoutOrder
                        all[i-1].LayoutOrder = lo; break
                    end
                end
            end,
            function()
                local all = getQBtns()
                for i, x in ipairs(all) do
                    if x == captB and i < #all then
                        local lo = captB.LayoutOrder
                        captB.LayoutOrder = all[i+1].LayoutOrder
                        all[i+1].LayoutOrder = lo; break
                    end
                end
            end
        )
        table.insert(quickEditOvs, ov)
    end
