        for _, partName in ipairs(vetPartsToRemove) do
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Part") and obj.Name == partName then
                    obj:Destroy()
                end
            end
        end
    end

    -- Supprime celles déjà présentes au chargement
    removeVetParts()

    -- Surveille les nouvelles instances ajoutées au workspace
    workspace.DescendantAdded:Connect(function(obj)
        if obj:IsA("Part") then
            for _, partName in ipairs(vetPartsToRemove) do
                if obj.Name == partName then
                    -- Attendre qu'elle soit bien parented (chargée) avant de détruire
                    task.defer(function()
                        if obj and obj.Parent then
                            obj:Destroy()
                        end
                    end)
                    break
                end
            end
        end
    end)
end)
