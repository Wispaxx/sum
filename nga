-- ====== GIVE PANEL EDIT MODE ======
local giveItemsList  = {}
local giveEditMode   = false
local giveEditOverlays = {}

local function collectGiveItems()
    giveItemsList = {}
    local tmp = {}
    for _, child in ipairs(gList:GetChildren()) do
        if child:IsA("Frame") then
            table.insert(tmp, child)
        end
    end
    table.sort(tmp, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
    for i, child in ipairs(tmp) do
        child.Name = "GiveItem_" .. i
        table.insert(giveItemsList, {row = child, idx = i})
    end
end

local function applyGivePanelOrder()
    local order = Config.GivePanelOrder
    if not order or #order == 0 then
        for i, item in ipairs(giveItemsList) do item.row.LayoutOrder = i end
        return
    end
    local idxToPos = {}
    for pos, idx in ipairs(order) do idxToPos[idx] = pos end
    for _, item in ipairs(giveItemsList) do
        item.row.LayoutOrder = idxToPos[item.idx] or item.idx
    end
end

local function saveGivePanelOrder()
    local sorted = {}
    for _, item in ipairs(giveItemsList) do table.insert(sorted, item) end
    table.sort(sorted, function(a, b) return a.row.LayoutOrder < b.row.LayoutOrder end)
    local order = {}
    for _, item in ipairs(sorted) do table.insert(order, item.idx) end
    Config.GivePanelOrder = order
    SaveConfig()
end

local function getGiveNeighbors(item)
    local myLO = item.row.LayoutOrder
    local above, below = nil, nil
    local aboveLO, belowLO = -math.huge, math.huge
    for _, other in ipairs(giveItemsList) do
        if other ~= item then
            local lo = other.row.LayoutOrder
            if lo < myLO and lo > aboveLO then aboveLO = lo; above = other end
            if lo > myLO and lo < belowLO then belowLO = lo; below = other end
        end
    end
    return above, below
end

local function enterGiveEditMode()
    collectGiveItems()  -- Recollectionner les items incluant currentWeaponButton
    giveEditMode = true
    gEditBtn.Text = "💾 Save"
    gEditBtn.TextColor3 = Theme.Success
    for _, item in ipairs(giveItemsList) do
        local btn = item.row:FindFirstChild("ActionBtn")
        if btn then btn.Visible = false end
        local captItem = item
        -- Flèches à droite, à la place du bouton GIVE
        local ov = CreateReorderOverlay(item.row, -10,
            function()   -- ▲
                local above, _ = getGiveNeighbors(captItem)
                if above then
                    local lo = captItem.row.LayoutOrder
                    captItem.row.LayoutOrder = above.row.LayoutOrder
                    above.row.LayoutOrder = lo
                end
            end,
            function()   -- ▼
                local _, below = getGiveNeighbors(captItem)
                if below then
                    local lo = captItem.row.LayoutOrder
                    captItem.row.LayoutOrder = below.row.LayoutOrder
                    below.row.LayoutOrder = lo
                end
            end
        )
        table.insert(giveEditOverlays, {ov = ov, btn = btn})
    end
end

local function exitGiveEditMode()
    giveEditMode = false
    gEditBtn.Text = "✏ Edit"
    gEditBtn.TextColor3 = Theme.Accent1
    for _, entry in ipairs(giveEditOverlays) do
        if entry.ov and entry.ov.Parent then entry.ov:Destroy() end
        if entry.btn then entry.btn.Visible = true end
    end
    giveEditOverlays = {}
    saveGivePanelOrder()
    ShowNotification(ThemedText("GIVE_PANEL"), "Order saved!")
end

gEditBtn.MouseButton1Click:Connect(function()
    if not giveEditMode then enterGiveEditMode() else exitGiveEditMode() end
end)

collectGiveItems()

-- Initialiser l'ordre par défaut si pas défini
if not Config.GivePanelOrder or #Config.GivePanelOrder == 0 then
    local defaultOrder = {}
    for i, item in ipairs(giveItemsList) do
        table.insert(defaultOrder, item.idx)
    end
    Config.GivePanelOrder = defaultOrder
end

applyGivePanelOrder()
